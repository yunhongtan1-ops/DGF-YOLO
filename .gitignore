# Keep only final DGF-YOLO additions from the experimental module folder
/ultralytics/nn/AddModules/*.py
!/ultralytics/nn/AddModules/__init__.py
!/ultralytics/nn/AddModules/GCF.py
!/ultralytics/nn/AddModules/SSFM_DGRM.py

# Keep only the final DGF-YOLO model config and the original YOLOv12 baseline config
/ultralytics/cfg/models/**/*.yaml
!/ultralytics/cfg/models/v12/yolov12.yaml
!/ultralytics/cfg/models/v12/yolov12-GCF-SSFM-DGRM.yaml

# Keep only the dataset template for this project
/ultralytics/cfg/datasets/*.yaml
!/ultralytics/cfg/datasets/dgf_yolo.yaml

# Built-in demo assets are not required for this project release
/ultralytics/assets/
